{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/agents/blueprint-absorber/restrict-paths.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash(leanblueprint *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(wc *)"
    ],
    "deny": [
      "Agent",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(lake *)",
      "Bash(rm *)",
      "Bash(mv *)"
    ]
  }
}
